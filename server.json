{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.legroom-ai/legroom",
  "description": "Legroom MCP server for compression, retrieval, and stats in MCP-compatible hosts.",
  "title": "Legroom",
  "websiteUrl": "https://legroom-ai.github.io/legroom/",
  "repository": {
    "url": "https://github.com/legroom-ai/legroom",
    "source": "github",
    "id": "1129940957"
  },
  "version": "0.32.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "legroom-ai",
      "version": "0.32.0",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "named",
          "name": "--from",
          "value": "legroom-ai[mcp]"
        }
      ],
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "legroom"
        },
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "serve"
        }
      ]
    }
  ]
}
